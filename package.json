{
  "name": "aigile",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test",
    "demo": "AIGILE_ENABLE_DEMO_CLI=1 bun run packages/cli/src/main.ts",
    "demo:agents": "AIGILE_ENABLE_DEMO_CLI=1 bun run packages/cli/src/main.ts demo:agents",
    "demo:workspace": "AIGILE_ENABLE_DEMO_CLI=1 bun run packages/cli/src/main.ts demo:workspace",
    "demo:github": "AIGILE_ENABLE_DEMO_CLI=1 bun run packages/cli/src/main.ts demo:github",
    "demo:linear": "AIGILE_ENABLE_DEMO_CLI=1 bun run packages/cli/src/main.ts demo:linear",
    "restate:service": "bun run packages/restate/src/main.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.21",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.1"
  }
}
